<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.RocketKids" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/rocket_orange</item>
        <item name="colorPrimaryVariant">#D04318</item>
        <item name="colorOnPrimary">@color/text_white</item>

        <item name="android:statusBarColor">@color/space_dark_bg</item>
        <item name="android:windowBackground">@color/space_dark_bg</item>
    </style>

    <style name="Widget.RocketKids.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border_grey</item>
        <item name="strokeWidth">2dp</item>
    </style>

    <style name="Widget.RocketKids.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/rocket_orange</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

</resources>