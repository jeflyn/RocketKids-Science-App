                    android:text="Media assets used in this application are sourced from the public domain or licensed under Creative Commons. All original creators are credited below."
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
