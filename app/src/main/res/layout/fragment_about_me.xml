                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="8dp"
                        android:layout_height="wrap_content"
                        android:text="•"
                        android:textColor="#FF6B00"
                        android:textSize="13sp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
