                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RocketKids Science is an interactive Android learning application designed for primary school children aged 6–12. It addresses the scientific inquiry: "
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="How do rockets overcome Earth's gravity?"
                android:textColor="#FF6B00"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="The app provides a multimodal learning experience combining text, images, audio, video content, and animated simulations to make complex scientific concepts accessible and engaging for young learners."
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5+ Media Types"
                        android:textColor="#00BAFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_quiz_option_selected"
                        android:backgroundTint="#0A2A3C" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 Activities"
                        android:textColor="#A855F7"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_quiz_option_selected"
                        android:backgroundTint="#1C0A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10-Q Quiz"
                        android:textColor="#10B981"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/bg_quiz_option_correct"
                        android:backgroundTint="#0D2B1F" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="16dp"
            app:strokeColor="#21262D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👨‍💻"
                        android:textSize="18sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
