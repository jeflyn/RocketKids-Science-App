<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚀 ROCKETKIDS SCIENCE APP"
            android:textColor="#FF5722"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How do rockets overcome\nEarth's gravity? 🌍"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.RocketKids.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#111622">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👋"
                    android:textSize="28sp"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Welcome, Space Explorer! Discover rocket science, play interactive games, and ace the quiz!"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="24dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_learn"
                style="@style/Widget.RocketKids.Card"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:backgroundTint="#1D2E54">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📚" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Learn Science" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Read, watch &amp; listen!" android:textColor="#94A3B8" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_play"
                style="@style/Widget.RocketKids.Card"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:backgroundTint="#3E1F5C">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Play &amp; Explore" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4 fun activities!" android:textColor="#94A3B8" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_quiz"
                style="@style/Widget.RocketKids.Card"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:backgroundTint="#134E3A">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Take a Quiz" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Test your knowledge!" android:textColor="#94A3B8" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_credits"
                style="@style/Widget.RocketKids.Card"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:backgroundTint="#4D380F">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="bottom"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐" android:textSize="28sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="About Me" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="16sp" android:layout_marginTop="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Our sources" android:textColor="#94A3B8" android:textSize="11sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>