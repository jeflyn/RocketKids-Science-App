<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E14"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quiz 🧠"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_quiz_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_counter_badge"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="1 / 10"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/txt_score_live"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/layout_top_bar"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="4dp"
            android:text="Score: 0"
            android:textColor="#10B981"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/txt_score_live"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#161B22"
            app:cardCornerRadius="16dp"
            app:strokeColor="#21262D"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/txt_question_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="🌍"
                    android:textSize="36sp" />

                <TextView
                    android:id="@+id/txt_question_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Question text will appear here..."
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layout_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/card_question"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/option_a"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_quiz_option_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/label_a"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_option_label"
                    android:gravity="center"
                    android:text="A"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_option_a"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Option A"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/option_b"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_quiz_option_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/label_b"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_option_label"
                    android:gravity="center"
                    android:text="B"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_option_b"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Option B"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/option_c"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_quiz_option_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/label_c"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_option_label"
                    android:gravity="center"
                    android:text="C"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_option_c"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Option C"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/option_d"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_quiz_option_default"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:id="@+id/label_d"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_option_label"
                    android:gravity="center"
                    android:text="D"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_option_d"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Option D"
                    android:textColor="#94A3B8"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_feedback"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_below="@id/layout_options"
            android:background="@drawable/bg_feedback_correct"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txt_feedback_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txt_feedback_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Correct!"
                android:textColor="#10B981"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_answer"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_below="@id/layout_feedback"
            android:layout_marginTop="12dp"
            android:backgroundTint="#FF6B00"
            android:text="Next Question →"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </RelativeLayout>

</androidx.core.widget.NestedScrollView>