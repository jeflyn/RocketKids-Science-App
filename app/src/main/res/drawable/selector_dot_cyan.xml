<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <stroke android:width="2dp" android:color="#FF6B00" /> </shape>
            </item>
            <item android:bottom="5dp" android:left="5dp" android:right="5dp" android:top="5dp">
                <shape android:shape="oval">
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <item android:bottom="7dp" android:left="7dp" android:right="7dp" android:top="7dp">
                <shape android:shape="oval">
                    <solid android:color="#FF6B00" /> </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <stroke android:width="2dp" android:color="#00E5FF" /> </shape>
            </item>
            <item android:bottom="5dp" android:left="5dp" android:right="5dp" android:top="5dp">
                <shape android:shape="oval">
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <item android:bottom="7dp" android:left="7dp" android:right="7dp" android:top="7dp">
                <shape android:shape="oval">
                    <solid android:color="#00E5FF" /> </shape>
            </item>
        </layer-list>
    </item>
</selector>